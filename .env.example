# Google OAuth (console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Anthropic API (console.anthropic.com)
ANTHROPIC_API_KEY=

# Google Sheets IDs (já existem no seu Drive)
SHEET_LANCAMENTOS_ID=your_sheet_id_here
SHEET_REGRAS_ID=your_sheet_id_here
SHEET_PIX_ID=your_sheet_id_here

# Emails autorizados (separados por vírgula)
AUTHORIZED_EMAILS=email1@gmail.com,email2@gmail.com

# Proporção de gastos
RAFAEL_SHARE=0.59
RENATA_SHARE=0.41
